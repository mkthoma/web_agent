# Copy this file to `.env` (in this same directory: Session 9/.env) and fill in
# the values you have keys for. The Session 9 gateway loads it explicitly via
# `load_dotenv(ROOT.parent / ".env")` in llm_gatewayV9/main.py — i.e. the .env
# beside this README, one level above the gateway package.
#
# Minimum to run anything: one worker provider + Ollama (for embeddings).
# Minimum to run research-heavy queries (web_search / fetch_url):
# TAVILY_API_KEY or fall back to DuckDuckGo (no key needed — the MCP server
# already handles failover). NOTE: the MCP tool server reads tool keys from
# `code/.env`, not this file — put TAVILY_API_KEY there (see code/.env.example).
#
# You do NOT need all providers. Set the ones you have; the gateway fails over
# through whichever subset is configured.

# ─── Worker providers (the gateway picks among them per request) ──────────
GEMINI_API_KEY=
# gemini-3.1-flash-lite: planner/comparator/formatter are STRICT-JSON skills. flash-lite
# has NO thinking budget, so it commits to JSON immediately. The full gemini-3.5-flash
# "thinks out loud" and emits a PLACEHOLDER plan ("nodes": [ ... ]) for the large planner
# prompt -> 0 nodes -> empty result. flash-lite was the original working value.
GEMINI_MODEL=gemini-3.1-flash-lite

GROQ_API_KEY=
# llama-3.3-70b: non-reasoning, clean JSON, 30 RPM — right for distiller/critic, and
# the recommended home for the browser fan-out (move it off Cerebras's 5 RPM in
# agent_routing.yaml).
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
# zai-glm-4.7: the only non-reasoning (clean-JSON) option on Cerebras; best for the
# single low-volume comparator. Cerebras free is 5 RPM + 8K ctx — never put a
# fan-out role here.
CEREBRAS_MODEL=zai-glm-4.7

NVIDIA_API_KEY=
# Primary offload for fan-out skills (distiller/comparator/browser agent tag).
# mistral-small-4 is a strong reasoning model at 40 RPM on NVIDIA NIM.
NVIDIA_MODEL=mistralai/mistral-small-4-119b-2603
# Alternative: qwen/qwen3.5-122b-a10b (reasoning; good failover-only)

GITHUB_ACCESS_TOKEN=
# gpt-4.1-mini: better text than Phi-4 for retriever/sandbox AND still vision-capable,
# so the browser Layer-3 vision fallback (gemini/github) stays intact.
GITHUB_MODEL=openai/gpt-4.1-mini

OPEN_ROUTER_API_KEY=
# Failover-only (reasoning model; excluded from strict-JSON failover rings).
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ─── Embedding (Ollama default; Gemini fallback uses GEMINI_API_KEY above) ─
# Session 9 reads the embedding model from EMBED_OLLAMA_MODEL (NOT OLLAMA_MODEL,
# which is the optional Ollama *chat* worker). Leave as-is for the 768-dim
# nomic vectors the FAISS index was built against.
OLLAMA_URL=http://localhost:11434
EMBED_OLLAMA_MODEL=nomic-embed-text
# OLLAMA_MODEL=                 # optional local CHAT worker (e.g. gemma4:31b)

# ─── MCP tool keys ─────────────────────────────────────────────────────────
# Read from code/.env by the MCP tool server, not from this file. Listed here
# for completeness; set it in code/.env.example → code/.env to take effect.
TAVILY_API_KEY=                 # optional; DDG is the fallback

# ─── Optional gateway tunables ─────────────────────────────────────────────
# LLM_ORDER=ollama,gemini,nvidia,groq,cerebras,openrouter,github
# (Session 9 gateway port is fixed at 8109 in gateway.py / llm_gatewayV9.)
